{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and stats",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "royaltyPoints": { "type": "integer" },
        "highestScore": { "type": "integer" },
        "longestStreak": { "type": "integer" },
        "favoriteCategory": { "type": "string" },
        "avatar": { "type": "string" },
        "playCount": { "type": "object" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username"]
    },
    "LeaderboardEntry": {
      "title": "LeaderboardEntry",
      "description": "Public leaderboard entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "royaltyPoints": { "type": "integer" },
        "highestScore": { "type": "integer" },
        "avatar": { "type": "string" }
      },
      "required": ["id", "username"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in the global chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "avatar": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "username", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents"
    },
    "/leaderboard/{userId}": {
      "schema": "LeaderboardEntry",
      "description": "Leaderboard documents"
    },
    "/chat/{messageId}": {
      "schema": "ChatMessage",
      "description": "Global chat messages"
    }
  }
}
