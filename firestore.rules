rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "nonsookoli757@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      let requiredFields = ['id', 'username', 'royaltyPoints', 'highestScore', 'longestStreak', 'favoriteCategory', 'avatar', 'playCount'];
      
      return data.keys().hasAll(requiredFields) &&
             data.id is string &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.royaltyPoints is number &&
             data.highestScore is number &&
             data.longestStreak is number &&
             data.favoriteCategory is string &&
             data.avatar is string &&
             data.playCount is map;
    }

    function isValidLeaderboard(data) {
      let requiredFields = ['id', 'username', 'royaltyPoints', 'highestScore', 'avatar'];
      
      return data.keys().hasAll(requiredFields) &&
             data.id is string &&
             data.username is string &&
             data.royaltyPoints is number &&
             data.highestScore is number &&
             data.avatar is string;
    }

    function isValidChatMessage(data) {
      let requiredFields = ['id', 'userId', 'username', 'avatar', 'text', 'createdAt'];
      
      return data.keys().hasAll(requiredFields) &&
             data.id is string &&
             data.userId is string &&
             data.username is string &&
             data.avatar is string &&
             data.text is string && data.text.size() > 0 && data.text.size() < 500 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /leaderboard/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidLeaderboard(request.resource.data);
      allow delete: if isAdmin();
    }

    match /chat/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId) && isValidChatMessage(request.resource.data);
      allow delete: if isAdmin() || (isAuthenticated() && isOwner(resource.data.userId));
    }
  }
}
