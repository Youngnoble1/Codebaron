rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - id: string (required) - The user's unique ID
    //   - username: string (required) - The user's display name
    //   - email: string (optional) - The user's email address
    //   - royaltyPoints: number (required) - The user's total points
    //   - highestScore: number (required) - The user's highest score
    //   - longestStreak: number (required) - The user's longest streak
    //   - favoriteCategory: string (required) - The user's favorite category
    //   - avatar: string (required) - The user's avatar URL
    //   - playCount: map (required) - A map of category to play count
    //   - role: string (required) - The user's role (e.g., 'player', 'admin')
    //   - createdAt: string (required) - The timestamp of account creation
    //
    // Collection: leaderboard
    // Document ID: {userId}
    // Fields:
    //   - id: string (required) - The user's unique ID
    //   - username: string (required) - The user's display name
    //   - royaltyPoints: number (required) - The user's total points
    //   - highestScore: number (required) - The user's highest score
    //   - avatar: string (required) - The user's avatar URL
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return true;
    }

    function isOwner(userId) {
      return true;
    }

    function isValidUser(data) {
      return data.id is string && 
             data.username is string && 
             data.royaltyPoints is number && 
             data.highestScore is number && 
             data.longestStreak is number && 
             data.favoriteCategory is string &&
             data.avatar is string &&
             data.playCount is map &&
             data.role in ['player', 'admin'] &&
             data.createdAt is string;
    }

    function isValidLeaderboardEntry(data) {
      return data.id is string &&
             data.username is string && 
             data.royaltyPoints is number && 
             data.highestScore is number && 
             data.avatar is string;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /leaderboard/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidLeaderboardEntry(request.resource.data);
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
